# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Supabase (get from supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (add these in Vercel dashboard > Settings > Environment Variables)
# NEVER prefix with VITE_ — these must stay server-side
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx
CRON_SECRET=generate-a-random-string-here

# Flip to OPEN in Vercel dashboard when the DPA portal opens
DPA_PORTAL_STATUS=CLOSED
